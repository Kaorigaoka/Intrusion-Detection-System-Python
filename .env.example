# ============================================================
# Hybrid IDS — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git. Add it to .gitignore.
# ============================================================

# --- Telegram ---
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Network ---
SENSOR_IP=192.168.8.8
SENSOR_IPS=192.168.8.8,192.168.8.21
CAPTURE_INTERFACE=eth0

# --- Model / Data Paths ---
MODEL_PATH=data/models/isolation_forest.model
NORMAL_DATA_PATH=data/models/cic_normal_features.npy

# --- AbuseIPDB (optional, free key at abuseipdb.com) ---
ABUSE_IP_KEY=

# --- Snort ---
SNORT_ALERT_FILE=/var/log/snort/alert_fast.txt

# --- Database ---
DB_PATH=data/runtime/ids_data.db

# --- Alert Log ---
LOG_FILE=data/runtime/ids_alerts.log
